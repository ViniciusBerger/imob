# Database
# Connect to the external PostgreSQL container
DATABASE_URL="postgresql://user:password@video_postgres:5432/pms_db?schema=public"

# Redis
REDIS_HOST="video_redis"
REDIS_PORT=6379

# Auth
JWT_SECRET="super_secret_secure_key_change_me"
JWT_EXPIRATION="1d"

# App
PORT=3000
NODE_ENV="production"
